# Stadia Maps API key (required for map tiles).
# Get one at https://client.stadiamaps.com/
VITE_STADIA_API_KEY=

# Optional: base path for production. Do not put in .env (so local build stays at /).
# For deploy, pass when running: VITE_BASE_PATH=/YourPath/ npm run deploy
# VITE_BASE_PATH=/HiSMaComp/
